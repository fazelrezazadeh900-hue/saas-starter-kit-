# ===== General =====
APP_NAME="SaaS Starter Kit"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ===== Security =====
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Database =====
# For local dev you can use SQLite:
# DATABASE_URL=sqlite:///./app.db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_starter

# ===== CORS =====
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ===== Email (for password reset, verification) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@yourapp.com
EMAILS_FROM_NAME="SaaS Starter Kit"

# ===== Stripe (optional billing provider) =====
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PRICE_ID_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_ID_YEARLY=price_xxxxxxxxxxxx

# ===== Crypto Payments (alternative billing provider, e.g. NOWPayments) =====
CRYPTO_PROVIDER_API_KEY=your-nowpayments-api-key
CRYPTO_IPN_SECRET=your-ipn-secret
CRYPTO_CALLBACK_URL=https://yourapp.com/api/v1/billing/crypto/webhook

# ===== First superuser (created on first run) =====
FIRST_SUPERUSER_EMAIL=admin@yourapp.com
FIRST_SUPERUSER_PASSWORD=change-this-password
